# Ignore everything by default. This repo should track source/config files only.
*

# Keep directories traversable for whitelist rules below.
!*/

# Git/project metadata
!.gitignore
!.gitmodules
!LICENSE
!LICENSE.*
!README*
!readme*
!CMakeLists.txt
!Makefile

# C/C++/CUDA source and headers
!*.c
!*.cc
!*.cpp
!*.cxx
!*.cu
!*.h
!*.hh
!*.hpp
!*.hxx
!*.inl
!*.ipp

# Build/config files needed to compile or run examples
!*.cmake
!*.cmake.in
!*.pc.in
!*.yaml
!*.yml
!*.json
!*.xml
!*.launch
!*.rviz
!*.conf
!*.cfg
!*.ini

# Code scripts
!*.py
!*.sh
!*.bash

# Package/build metadata that is source-like
!package.xml
!manifest.xml
!Dockerfile
!docker-compose.yml

# Always ignore build products and generated binaries.
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile.user
*.user
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.bin
*.app
lib/

# Ignore datasets, logs, generated results, and heavy artifacts.
*.bag
*.db3
*.mcap
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.pdf
*.png
*.jpg
*.jpeg
*.bmp
*.gif
*.tif
*.tiff
*.mp4
*.avi
*.mov
*.mkv
*.txt
*.log
*.csv
*.npy
*.npz
*.ply
*.pcd
*.las
*.laz
*.onnx
*.engine
*.weights
*.pt
*.pth

# Python/editor/cache noise
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.cache/
.vscode/
.idea/

# Common generated output directories in this workspace
Examples/ROS/
Examples/Monocular/EuRoC.yaml
Examples/Monocular/lidarImu.yaml
Examples/Monocular/map_openrealm.yaml
Examples/Monocular/map2d_ours.yaml
Examples/Monocular/map2d_zicai.yaml
Examples/Monocular/mydataset.yaml
results/
resultimag/
output_traject/
evo/
extractgps/
script/*
!script/align_gps_to_frames.py
tile-server/
vision_opencv-noetic/
